{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "openacc",
      "camelcase": "OpenACC",
      "scope": "source.openacc",
      "path": ".",
      "injection-regex": "^acc$",
      "file-types": [
        "acc"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "Unlicense",
    "description": "OpenACC directive grammar for tree-sitter",
    "authors": [
      {
        "name": "Loïc Reynier",
        "email": "contact@loicreynier.fr"
      }
    ],
    "links": {
      "repository": "https://github.com/loicreynier/tree-sitter-openacc"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
